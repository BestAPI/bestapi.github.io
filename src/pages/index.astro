---
import Layout from '../layouts/Layout.astro';
import { categories } from '../data/apis';

const title = "BestAPI";
const description = "Discover and explore APIs from around the world.";
---

<Layout title={title} description={description}>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
    <a href="/apis" class="p-4 bg-white dark:bg-gray-800 rounded-md border border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600">
      <h2 class="font-medium text-gray-900 dark:text-white mb-1">Browse All APIs</h2>
      <p class="text-gray-600 dark:text-gray-300 text-xs">Explore our complete collection</p>
    </a>
    <a href="/categories" class="p-4 bg-white dark:bg-gray-800 rounded-md border border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600">
      <h2 class="font-medium text-gray-900 dark:text-white mb-1">Browse Categories</h2>
      <p class="text-gray-600 dark:text-gray-300 text-xs">Find APIs by category</p>
    </a>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-md border border-gray-200 dark:border-gray-700 p-4">
    <h2 class="font-medium text-gray-900 dark:text-white mb-3">Popular Categories</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
      {categories.map((category) => (
        <a href={`/category/${category.toLowerCase()}`} class="p-2 bg-gray-50 dark:bg-gray-700 rounded-md hover:bg-gray-100 dark:hover:bg-gray-600 text-center">
          <span class="text-gray-900 dark:text-white text-xs">{category}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>